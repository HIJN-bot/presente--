# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=presente
DB_PORT=5432

# Backend Configuration
API_BASE_URL=http://localhost:8000
ENV=development

# Service Ports
BACKEND_PORT=8000
FRONTEND_PORT=80

# Frontend Configuration - URL donde el navegador hablará con el backend
# LOCAL: http://localhost:8000
# DOCKER: http://localhost:8000
# PRODUCTION (Render): https://tu-app.render.com
VITE_API_BASE_URL=http://localhost:8000

# CORS Configuration (Backend)
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# JWT/Security (if needed in future)
# SECRET_KEY=your_secret_key_here
# ALGORITHM=HS256

# Email Configuration (if needed in future)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=your_email@gmail.com
# SENDER_PASSWORD=your_app_password
